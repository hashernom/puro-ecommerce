<section class="py-5">
    <div class="container">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">
                    Transforma tu <span class="text-success">Bienestar</span> Naturalmente
                </h1>
                <p class="lead text-secondary mb-4">
                    Shots vitamínicos premium elaborados con los mejores ingredientes naturales.
                    Energía pura para tu estilo de vida saludable.
                </p>
                <div class="d-flex gap-3">
                    <a href="/products" class="btn btn-success btn-lg">
                        Explorar Productos <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center mt-4 mt-lg-0">
                <div class="bg-light rounded-4 p-5" style="min-height: 300px; display:flex; align-items:center; justify-content:center;">
                    <div>
                        <i class="bi bi-leaf text-success" style="font-size: 5rem;"></i>
                        <p class="mt-3 text-secondary">PURO Natural Shots</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Nuestros Favoritos</h2>
        <div class="row" id="featured-products">
            <% if (typeof featuredProducts !== 'undefined' && featuredProducts.length > 0) { %>
                <% featuredProducts.forEach(product => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title"><%= product.name %></h5>
                                <p class="card-text text-secondary"><%= product.description || 'Shot natural premium' %></p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="h5 text-success mb-0">$<%= parseFloat(product.price).toFixed(2) %></span>
                                    <a href="/products" class="btn btn-outline-success btn-sm">Ver más</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center">
                    <p class="text-secondary">Cargando productos...</p>
                    <a href="/products" class="btn btn-success">Ver catálogo completo</a>
                </div>
            <% } %>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-4">
                <i class="bi bi-leaf text-success display-4 mb-3"></i>
                <h4>100% Natural</h4>
                <p class="text-secondary">Ingredientes orgánicos y sin aditivos artificiales</p>
            </div>
            <div class="col-md-4 mb-4">
                <i class="bi bi-lightning text-warning display-4 mb-3"></i>
                <h4>Energía Instantánea</h4>
                <p class="text-secondary">Absorción rápida para resultados inmediatos</p>
            </div>
            <div class="col-md-4 mb-4">
                <i class="bi bi-award text-primary display-4 mb-3"></i>
                <h4>Calidad Premium</h4>
                <p class="text-secondary">Los más altos estándares de producción</p>
            </div>
        </div>
    </div>
</section>
