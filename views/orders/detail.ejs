<div class="container mt-5 mb-5">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Inicio</a></li>
      <li class="breadcrumb-item"><a href="/orders/user" class="text-decoration-none">Mis Pedidos</a></li>
      <li class="breadcrumb-item active">Pedido #<%= order.id %></li>
    </ol>
  </nav>

  <% const colors = {pending:'warning',processing:'info',shipped:'primary',delivered:'success',cancelled:'danger'} %>
  <% const labels = {pending:'Pendiente',processing:'Procesando',shipped:'Enviado',delivered:'Entregado',cancelled:'Cancelado'} %>

  <div class="row g-4">
    <!-- Detalle de items -->
    <div class="col-lg-8">
      <div class="card shadow-sm rounded-4 border-0 mb-4">
        <div class="card-header bg-light py-3">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Pedido #<%= order.id %></h5>
            <span class="badge bg-<%= colors[order.status] || 'secondary' %> fs-6">
              <%= labels[order.status] || order.status %>
            </span>
          </div>
        </div>
        <div class="card-body p-0">
          <% if (order.orderDetails && order.orderDetails.length > 0) { %>
            <% order.orderDetails.forEach(item => { %>
            <div class="d-flex align-items-center p-3 border-bottom gap-3">
              <img src="<%= item.product ? item.product.image_url : '/images/default-product.svg' %>"
                alt="" style="width:70px;height:70px;object-fit:cover;border-radius:10px;"
                onerror="this.src='/images/default-product.svg'">
              <div class="flex-grow-1">
                <h6 class="mb-0 fw-bold"><%= item.product ? item.product.name : 'Producto' %></h6>
                <small class="text-secondary">Cantidad: <%= item.quantity %> × $<%= parseFloat(item.unit_price).toFixed(2) %></small>
              </div>
              <strong class="text-success">$<%= parseFloat(item.quantity * item.unit_price).toFixed(2) %></strong>
            </div>
            <% }); %>
          <% } else { %>
            <p class="text-secondary p-4 mb-0">Sin productos registrados.</p>
          <% } %>
        </div>
      </div>

      <!-- Dirección -->
      <% if (order.shipping_address) { %>
      <div class="card shadow-sm rounded-4 border-0">
        <div class="card-body">
          <h6 class="fw-bold mb-2"><i class="bi bi-geo-alt me-2 text-success"></i>Dirección de envío</h6>
          <p class="mb-0 text-secondary"><%= order.shipping_address %></p>
          <% if (order.notes) { %>
            <hr class="my-2">
            <small class="text-secondary"><strong>Notas:</strong> <%= order.notes %></small>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Resumen -->
    <div class="col-lg-4">
      <div class="card shadow-sm rounded-4 border-0 sticky-top" style="top:100px">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">Resumen</h5>
          <div class="d-flex justify-content-between mb-2 text-secondary">
            <span>Fecha</span>
            <span><%= new Date(order.created_at).toLocaleDateString('es-CO') %></span>
          </div>
          <div class="d-flex justify-content-between mb-2 text-secondary">
            <span>Items</span>
            <span><%= order.orderDetails ? order.orderDetails.length : 0 %></span>
          </div>
          <hr>
          <div class="d-flex justify-content-between fw-bold h5">
            <span>Total</span>
            <span class="text-success">$<%= parseFloat(order.total_amount).toFixed(2) %></span>
          </div>
          <% if (order.status === 'pending' || order.status === 'processing') { %>
            <button class="btn btn-outline-danger w-100 mt-3"
              onclick="cancelarPedido(<%= order.id %>)">
              <i class="bi bi-x-circle me-2"></i>Cancelar pedido
            </button>
          <% } %>
          <a href="/orders/user" class="btn btn-outline-secondary w-100 mt-2">
            <i class="bi bi-arrow-left me-2"></i>Mis pedidos
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
async function cancelarPedido(id) {
    if (!confirm('¿Estás seguro de cancelar este pedido?')) return;
    try {
        const res  = await fetch(`/orders/${id}/cancel`, { method: 'PUT', headers: {'Content-Type':'application/json'} });
        const data = await res.json();
        if (data.success) window.location.reload();
        else alert(data.message || 'Error al cancelar');
    } catch (e) { alert('Error de conexión'); }
}
</script>
