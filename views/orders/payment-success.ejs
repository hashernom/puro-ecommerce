<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-5 text-center">
                        <div class="mb-4">
                            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex p-4 mb-3">
                                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                            </div>
                            <h1 class="h2 fw-bold text-success">¡Pago Exitoso!</h1>
                            <p class="text-muted mb-0">Tu pedido ha sido confirmado y está siendo procesado.</p>
                        </div>

                        <div class="alert alert-success border-0 bg-light-success mb-4">
                            <div class="d-flex">
                                <i class="bi bi-info-circle-fill text-success me-3 mt-1"></i>
                                <div>
                                    <h5 class="alert-heading mb-1">Pedido #<%= order.id %></h5>
                                    <p class="mb-0">Recibirás un correo de confirmación con los detalles de tu compra.</p>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 bg-light mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">Resumen del pedido</h5>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Total pagado:</span>
                                    <span class="fw-bold h5 text-success">$<%= parseFloat(order.total_amount).toFixed(2) %></span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Estado:</span>
                                    <span class="badge bg-success rounded-pill"><%= order.getStatusInSpanish ? order.getStatusInSpanish() : 'Procesando' %></span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">Fecha:</span>
                                    <span><%= new Date(order.created_at).toLocaleDateString('es-ES') %></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-3">
                            <a href="/orders/user" class="btn btn-outline-success btn-lg">
                                <i class="bi bi-list-check me-2"></i> Ver mis pedidos
                            </a>
                            <a href="/products" class="btn btn-success btn-lg">
                                <i class="bi bi-cart-plus me-2"></i> Seguir comprando
                            </a>
                            <a href="/" class="btn btn-link text-decoration-none">
                                <i class="bi bi-house me-1"></i> Volver al inicio
                            </a>
                        </div>

                        <hr class="my-4">

                        <div class="text-muted small">
                            <p class="mb-1">
                                <i class="bi bi-envelope me-1"></i> 
                                Si tienes preguntas sobre tu pedido, contáctanos en 
                                <a href="mailto:soporte@puro.com" class="text-decoration-none">soporte@puro.com</a>
                            </p>
                            <p class="mb-0">
                                <i class="bi bi-clock-history me-1"></i> 
                                El tiempo de entrega estimado es de 3-5 días hábiles.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>