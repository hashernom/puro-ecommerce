<div class="container mt-5 mb-5">
    <h1 class="fw-bold mb-4">Mi Carrito</h1>
    <div class="row">
        <div class="col-lg-8">
            <div id="cart-items-container">
                <div class="text-center py-5">
                    <div class="spinner-border text-success" role="status"></div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm rounded-4 sticky-top" style="top: 100px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Resumen del pedido</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span id="cart-subtotal">$0.00</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-secondary">
                        <span>Envío</span>
                        <span>A calcular</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold h5">
                        <span>Total</span>
                        <span id="cart-total">$0.00</span>
                    </div>
                    <div class="d-grid mt-4">
                        <button id="checkout-btn" class="btn btn-success btn-lg" onclick="proceedToCheckout()">
                            <i class="bi bi-bag-check me-2"></i>Proceder al pago
                        </button>
                    </div>
                    <a href="/products" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="bi bi-arrow-left me-2"></i>Seguir comprando
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para dirección de envío -->
<div class="modal fade" id="checkoutModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar pedido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Dirección de envío *</label>
                    <textarea class="form-control" id="shipping_address" rows="3" placeholder="Calle, número, ciudad, departamento..." required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Notas adicionales (opcional)</label>
                    <textarea class="form-control" id="order_notes" rows="2" placeholder="Instrucciones especiales..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" onclick="submitOrder()">
                    <i class="bi bi-bag-check me-2"></i>Confirmar pedido
                </button>
            </div>
        </div>
    </div>
</div>
<script src="/js/orders.js"></script>
