<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Gestión de Pedidos</h1>
    <span class="badge bg-secondary fs-6"><%= totalOrders %> pedidos</span>
  </div>

  <!-- Filtro por estado -->
  <div class="d-flex gap-2 mb-4 flex-wrap">
    <% ['all','pending','processing','shipped','delivered','cancelled'].forEach(s => { %>
      <a href="/admin/orders?status=<%= s %>"
        class="btn btn-sm <%= status === s ? 'btn-success' : 'btn-outline-secondary' %>">
        <%= s === 'all' ? 'Todos' : s === 'pending' ? 'Pendientes' : s === 'processing' ? 'Procesando' :
            s === 'shipped' ? 'Enviados' : s === 'delivered' ? 'Entregados' : 'Cancelados' %>
      </a>
    <% }); %>
  </div>

  <!-- Tabla -->
  <div class="card shadow-sm rounded-4 border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr><th>#</th><th>Cliente</th><th>Fecha</th><th>Total</th><th>Items</th><th>Estado</th><th>Cambiar estado</th></tr>
          </thead>
          <tbody>
            <% const colors = {pending:'warning',processing:'info',shipped:'primary',delivered:'success',cancelled:'danger'} %>
            <% const labels = {pending:'Pendiente',processing:'Procesando',shipped:'Enviado',delivered:'Entregado',cancelled:'Cancelado'} %>
            <% if (orders.length === 0) { %>
              <tr><td colspan="7" class="text-center py-4 text-secondary">No hay pedidos</td></tr>
            <% } else { %>
              <% orders.forEach(o => { %>
              <tr>
                <td><strong>#<%= o.id %></strong></td>
                <td>
                  <span class="fw-semibold"><%= o.user ? `${o.user.first_name} ${o.user.last_name}` : 'N/A' %></span><br>
                  <small class="text-secondary"><%= o.user ? o.user.email : '' %></small>
                </td>
                <td><small><%= new Date(o.created_at).toLocaleDateString('es-CO') %></small></td>
                <td class="fw-bold text-success">$<%= parseFloat(o.total_amount).toFixed(2) %></td>
                <td><%= o.orderDetails ? o.orderDetails.length : 0 %> items</td>
                <td><span class="badge bg-<%= colors[o.status] || 'secondary' %>"><%= labels[o.status] || o.status %></span></td>
                <td>
                  <select class="form-select form-select-sm" style="min-width:130px"
                    onchange="cambiarEstado(<%= o.id %>, this.value)">
                    <% ['pending','processing','shipped','delivered','cancelled'].forEach(s => { %>
                      <option value="<%= s %>" <%= o.status===s ? 'selected':'' %>><%= labels[s] %></option>
                    <% }); %>
                  </select>
                </td>
              </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Paginación -->
  <% if (totalPages > 1) { %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center">
      <% for(let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="/admin/orders?status=<%= status %>&page=<%= i %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </nav>
  <% } %>
</div>
<script src="/js/admin.js"></script>
