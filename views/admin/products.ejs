<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Gestión de Productos</h1>
    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalProducto">
      <i class="bi bi-plus-lg me-2"></i>Nuevo Producto
    </button>
  </div>

  <!-- Filtros -->
  <form method="GET" action="/admin/products" class="row g-2 mb-4">
    <div class="col-md-6">
      <input type="text" name="search" class="form-control" placeholder="Buscar por nombre..." value="<%= search %>">
    </div>
    <div class="col-md-3">
      <select name="status" class="form-select">
        <option value="all"    <%= status==='all'    ? 'selected':'' %>>Todos</option>
        <option value="active" <%= status==='active' ? 'selected':'' %>>Activos</option>
        <option value="inactive" <%= status==='inactive' ? 'selected':'' %>>Inactivos</option>
      </select>
    </div>
    <div class="col-md-3">
      <button type="submit" class="btn btn-outline-secondary w-100">Filtrar</button>
    </div>
  </form>

  <!-- Tabla de productos -->
  <div class="card shadow-sm rounded-4 border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>#</th><th>Imagen</th><th>Nombre</th><th>Precio</th>
              <th>Stock</th><th>Estado</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (products.length === 0) { %>
              <tr><td colspan="7" class="text-center py-4 text-secondary">No hay productos</td></tr>
            <% } else { %>
              <% products.forEach(p => { %>
              <tr>
                <td><%= p.id %></td>
                <td>
                  <img src="<%= p.image_url || '/images/default-product.svg' %>" alt="<%= p.name %>"
                    style="width:50px;height:50px;object-fit:cover;border-radius:8px;">
                </td>
                <td class="fw-semibold"><%= p.name %></td>
                <td>$<%= parseFloat(p.price).toFixed(2) %></td>
                <td>
                  <span class="badge <%= p.stock <= 5 ? 'bg-danger' : 'bg-success' %>">
                    <%= p.stock %> uds
                  </span>
                </td>
                <td>
                  <span class="badge <%= p.is_active ? 'bg-success' : 'bg-secondary' %>">
                    <%= p.is_active ? 'Activo' : 'Inactivo' %>
                  </span>
                </td>
                <td>
                  <button class="btn btn-sm btn-outline-primary me-1"
                    onclick="editProduct(<%= JSON.stringify(p) %>)">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <button class="btn btn-sm btn-outline-danger"
                    onclick="toggleProduct(<%= p.id %>, <%= p.is_active %>)">
                    <i class="bi bi-<%= p.is_active ? 'eye-slash' : 'eye' %>"></i>
                  </button>
                </td>
              </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Paginación -->
  <% if (totalPages > 1) { %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center">
      <% for(let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="/admin/products?search=<%= search %>&status=<%= status %>&page=<%= i %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </nav>
  <% } %>
</div>

<!-- Modal crear/editar producto -->
<div class="modal fade" id="modalProducto" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalProductoTitle">Nuevo Producto</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="productoId">
        <div class="row g-3">
          <div class="col-md-8">
            <label class="form-label fw-semibold">Nombre *</label>
            <input type="text" id="productoNombre" class="form-control" required>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">Precio *</label>
            <div class="input-group">
              <span class="input-group-text">$</span>
              <input type="number" id="productoPrecio" class="form-control" step="0.01" min="0.01" required>
            </div>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">Stock *</label>
            <input type="number" id="productoStock" class="form-control" min="0" required>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">Categoría</label>
            <select id="productoCategoria" class="form-select">
                <option value="natural">Natural</option>
                <option value="energetico">Energético</option>
                <option value="detox">Detox</option>
                <option value="inmunologico">Inmunológico</option>
            </select>
          </div>
          <div class="col-md-4 d-flex align-items-center mt-3">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="productoActivo" checked>
                <label class="form-check-label">Activo</label>
            </div>
          </div>
          <div class="col-md-8">
            <label class="form-label fw-semibold">URL de Imagen</label>
            <input type="text" id="productoImagen" class="form-control" placeholder="/images/nombre.jpg">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Descripción</label>
            <textarea id="productoDescripcion" class="form-control" rows="3"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button class="btn btn-success" onclick="guardarProducto()">
          <i class="bi bi-check-lg me-2"></i>Guardar
        </button>
      </div>
    </div>
  </div>
</div>
<script src="/js/admin.js?v=20260413"></script>
