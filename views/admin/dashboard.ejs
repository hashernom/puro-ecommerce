<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Panel de Administración</h1>
        <span class="badge bg-success fs-6">Admin</span>
    </div>

    <!-- Estadísticas principales -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card shadow-sm rounded-4 border-0 bg-success text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 opacity-75">Usuarios</p>
                            <h3 class="mb-0 fw-bold"><%= typeof stats !== 'undefined' ? stats.totalUsers : 0 %></h3>
                        </div>
                        <i class="bi bi-people display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm rounded-4 border-0 bg-primary text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 opacity-75">Productos</p>
                            <h3 class="mb-0 fw-bold"><%= typeof stats !== 'undefined' ? stats.totalProducts : 0 %></h3>
                        </div>
                        <i class="bi bi-box display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm rounded-4 border-0 bg-warning text-dark">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 opacity-75">Pedidos</p>
                            <h3 class="mb-0 fw-bold"><%= typeof stats !== 'undefined' ? stats.totalOrders : 0 %></h3>
                        </div>
                        <i class="bi bi-bag display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm rounded-4 border-0 bg-info text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 opacity-75">Ingresos Totales</p>
                            <h3 class="mb-0 fw-bold">$<%= typeof stats !== 'undefined' ? parseFloat(stats.totalRevenue).toFixed(0) : 0 %></h3>
                        </div>
                        <i class="bi bi-cash-stack display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Estadísticas secundarias -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 text-secondary">Pedidos (último mes)</p>
                            <h4 class="mb-0 fw-bold"><%= typeof stats !== 'undefined' ? stats.recentMonthOrders : 0 %></h4>
                        </div>
                        <i class="bi bi-calendar-month text-primary display-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 text-secondary">Ingresos (último mes)</p>
                            <h4 class="mb-0 fw-bold">$<%= typeof stats !== 'undefined' ? parseFloat(stats.recentMonthRevenue).toFixed(0) : 0 %></h4>
                        </div>
                        <i class="bi bi-currency-dollar text-success display-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 text-secondary">Promedio por pedido</p>
                            <h4 class="mb-0 fw-bold">$<%= typeof stats !== 'undefined' ? stats.averageOrderValue : 0 %></h4>
                        </div>
                        <i class="bi bi-graph-up text-warning display-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Links rápidos -->
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <a href="/admin/products" class="card shadow-sm rounded-4 text-decoration-none text-dark h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-box-seam text-primary display-4 mb-2"></i>
                    <h5 class="fw-bold">Gestionar Productos</h5>
                    <p class="text-secondary small">Crear, editar y eliminar productos</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/admin/orders" class="card shadow-sm rounded-4 text-decoration-none text-dark h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-bag-check text-warning display-4 mb-2"></i>
                    <h5 class="fw-bold">Gestionar Pedidos</h5>
                    <p class="text-secondary small">Ver y actualizar estado de pedidos</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/admin/users" class="card shadow-sm rounded-4 text-decoration-none text-dark h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-people text-success display-4 mb-2"></i>
                    <h5 class="fw-bold">Gestionar Usuarios</h5>
                    <p class="text-secondary small">Ver y administrar usuarios</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Sección de pedidos recientes -->
    <div class="row g-4 mb-5">
        <div class="col-md-8">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0">Pedidos Recientes</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Cliente</th>
                                    <th>Total</th>
                                    <th>Estado</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (recentOrders && recentOrders.length > 0) { %>
                                    <% recentOrders.forEach(order => { %>
                                        <tr>
                                            <td><a href="/admin/orders/<%= order.id %>" class="text-decoration-none">#<%= order.id %></a></td>
                                            <td><%= order.user.first_name %> <%= order.user.last_name %></td>
                                            <td>$<%= parseFloat(order.total_amount).toFixed(2) %></td>
                                            <td>
                                                <span class="badge bg-<%= 
                                                    order.status === 'pending' ? 'warning' : 
                                                    order.status === 'processing' ? 'info' : 
                                                    order.status === 'shipped' ? 'primary' : 
                                                    order.status === 'delivered' ? 'success' : 
                                                    order.status === 'cancelled' ? 'danger' : 'secondary'
                                                %>">
                                                    <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                                                </span>
                                            </td>
                                            <td><%= new Date(order.created_at).toLocaleDateString('es-CO') %></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">No hay pedidos recientes</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Productos con bajo stock -->
        <div class="col-md-4">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0">Productos con Bajo Stock</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <% if (lowStockProducts && lowStockProducts.length > 0) { %>
                            <% lowStockProducts.forEach(product => { %>
                                <a href="/admin/products/<%= product.id %>" class="list-group-item list-group-item-action border-0 py-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1 fw-bold"><%= product.name %></h6>
                                            <small class="text-muted">Stock: <%= product.stock %> unidades</small>
                                        </div>
                                        <span class="badge bg-<%= product.stock === 0 ? 'danger' : 'warning' %>">
                                            <%= product.stock === 0 ? 'Agotado' : 'Bajo' %>
                                        </span>
                                    </div>
                                </a>
                            <% }); %>
                        <% } else { %>
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-check-circle display-5 mb-3"></i>
                                <p class="mb-0">Todo el stock está en buen nivel</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Productos más vendidos -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0">Productos Más Vendidos (Último mes)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <% if (topProducts && topProducts.length > 0) { %>
                            <% topProducts.forEach((item, index) => { %>
                                <div class="list-group-item border-0 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="position-relative me-3">
                                            <span class="badge bg-primary rounded-circle position-absolute top-0 start-100 translate-middle" style="z-index: 1;">
                                                <%= index + 1 %>
                                            </span>
                                            <% if (item.product_image) { %>
                                                <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="rounded" width="50" height="50" style="object-fit: cover;">
                                            <% } else { %>
                                                <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                                    <i class="bi bi-box text-secondary"></i>
                                                </div>
                                            <% } %>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1 fw-bold"><%= item.product_name %></h6>
                                            <small class="text-muted">Vendidos: <%= item.total_sold %> unidades</small>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-bold">$<%= parseFloat(item.product_price).toFixed(2) %></div>
                                            <small class="text-success">Ingreso: $<%= (item.total_sold * parseFloat(item.product_price)).toFixed(2) %></small>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-bar-chart display-5 mb-3"></i>
                                <p class="mb-0">No hay datos de ventas del último mes</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estadísticas de pedidos por estado -->
        <div class="col-md-6">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0">Pedidos por Estado</h5>
                </div>
                <div class="card-body">
                    <% if (orderStatusStats && orderStatusStats.length > 0) { %>
                        <% orderStatusStats.forEach(stat => { %>
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-medium">
                                        <%= stat.status.charAt(0).toUpperCase() + stat.status.slice(1) %>
                                    </span>
                                    <span class="fw-bold"><%= stat.count %> pedidos</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <%
                                        const totalOrders = orderStatusStats.reduce((sum, s) => sum + parseInt(s.count), 0);
                                        const percentage = totalOrders > 0 ? (stat.count / totalOrders * 100) : 0;
                                        const barColor = stat.status === 'pending' ? 'warning' :
                                                         stat.status === 'processing' ? 'info' :
                                                         stat.status === 'shipped' ? 'primary' :
                                                         stat.status === 'delivered' ? 'success' :
                                                         stat.status === 'cancelled' ? 'danger' : 'secondary';
                                    %>
                                    <div class="progress-bar bg-<%= barColor %>" role="progressbar" style="width: <%= percentage %>%;"></div>
                                </div>
                                <small class="text-muted d-block mt-1">
                                    Total: $<%= parseFloat(stat.total || 0).toFixed(2) %>
                                </small>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-pie-chart display-5 mb-3"></i>
                            <p class="mb-0">No hay datos de pedidos por estado</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
