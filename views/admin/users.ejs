<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Gestión de Usuarios</h1>
    <span class="badge bg-secondary fs-6"><%= totalUsers %> usuarios</span>
  </div>

  <!-- Filtros -->
  <form method="GET" action="/admin/users" class="row g-2 mb-4">
    <div class="col-md-6">
      <input type="text" name="search" class="form-control" placeholder="Buscar por nombre o email..." value="<%= search %>">
    </div>
    <div class="col-md-3">
      <select name="role" class="form-select">
        <option value="all"    <%= role==='all'    ? 'selected':'' %>>Todos los roles</option>
        <option value="client" <%= role==='client' ? 'selected':'' %>>Clientes</option>
        <option value="admin"  <%= role==='admin'  ? 'selected':'' %>>Administradores</option>
      </select>
    </div>
    <div class="col-md-3">
      <button type="submit" class="btn btn-outline-secondary w-100">Filtrar</button>
    </div>
  </form>

  <!-- Tabla -->
  <div class="card shadow-sm rounded-4 border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr><th>#</th><th>Nombre</th><th>Email</th><th>Rol</th><th>Registrado</th><th>Cambiar rol</th></tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr><td colspan="6" class="text-center py-4 text-secondary">No hay usuarios</td></tr>
            <% } else { %>
              <% users.forEach(u => { %>
              <tr>
                <td><%= u.id %></td>
                <td class="fw-semibold"><%= u.first_name %> <%= u.last_name %></td>
                <td class="text-secondary"><%= u.email %></td>
                <td>
                  <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-success' %>">
                    <%= u.role === 'admin' ? 'Admin' : 'Cliente' %>
                  </span>
                </td>
                <td><small><%= new Date(u.created_at).toLocaleDateString('es-CO') %></small></td>
                <td>
                  <select class="form-select form-select-sm" style="min-width:130px"
                    onchange="cambiarRol(<%= u.id %>, this.value)">
                    <option value="client" <%= u.role==='client' ? 'selected':'' %>>Cliente</option>
                    <option value="admin"  <%= u.role==='admin'  ? 'selected':'' %>>Admin</option>
                  </select>
                </td>
              </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Paginación -->
  <% if (totalPages > 1) { %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center">
      <% for(let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="/admin/users?search=<%= search %>&role=<%= role %>&page=<%= i %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </nav>
  <% } %>
</div>
<script src="/js/admin.js"></script>
