<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="text-success mb-2">Bienvenido de vuelta</h2>
                        <p class="text-secondary">Ingresa a tu cuenta PURO</p>
                    </div>

                    <form method="POST" action="/auth/login">
                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-envelope text-secondary"></i></span>
                                <input type="email" class="form-control" id="email" name="email"
                                    value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
                                    placeholder="tu@email.com" required>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label for="password" class="form-label fw-semibold">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock text-secondary"></i></span>
                                <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword()">
                                    <i class="bi bi-eye" id="toggleIcon"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                            </button>
                        </div>
                    </form>

                    <hr class="my-4">
                    <div class="text-center">
                        <p class="mb-2">¿No tienes cuenta?</p>
                        <a href="/auth/register" class="btn btn-outline-success">Crear cuenta nueva</a>
                    </div>
                </div>
            </div>
            <div class="card mt-4 bg-light border-0">
                <div class="card-body p-3">
                    <h6 class="text-secondary mb-2"><i class="bi bi-info-circle me-1"></i>Cuentas de prueba:</h6>
                    <small class="text-muted d-block"><strong>Admin:</strong> admin@puro.co / Admin123</small>
                    <small class="text-muted d-block"><strong>Cliente:</strong> cliente@puro.co / Cliente123</small>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
function togglePassword() {
    const input = document.getElementById('password');
    const icon = document.getElementById('toggleIcon');
    input.type = input.type === 'password' ? 'text' : 'password';
    icon.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
}
</script>
