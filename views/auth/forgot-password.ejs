<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <a href="/" class="text-decoration-none">
                                <h1 class="h3 fw-bold text-success">PURO</h1>
                                <p class="text-muted small">Premium Natural Shots</p>
                            </a>
                            <h2 class="h4 fw-bold mt-3">Recuperar contraseña</h2>
                            <p class="text-muted">Ingresa tu email para recibir un enlace de recuperación.</p>
                        </div>

                        <% if (success) { %>
                            <div class="alert alert-success border-0 bg-light-success mb-4">
                                <div class="d-flex">
                                    <i class="bi bi-check-circle-fill text-success me-3 mt-1"></i>
                                    <div>
                                        <h5 class="alert-heading mb-1">¡Email enviado!</h5>
                                        <p class="mb-0">Revisa tu bandeja de entrada y sigue las instrucciones para restablecer tu contraseña.</p>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                        <% if (errors && errors.length > 0) { %>
                            <div class="alert alert-danger border-0 bg-light-danger mb-4">
                                <ul class="mb-0 ps-3">
                                    <% errors.forEach(error => { %>
                                        <li><%= error.msg %></li>
                                    <% }); %>
                                </ul>
                            </div>
                        <% } %>

                        <form method="POST" action="/auth/forgot-password">
                            <div class="mb-4">
                                <label for="email" class="form-label fw-semibold">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-envelope text-muted"></i>
                                    </span>
                                    <input type="email" 
                                           class="form-control border-start-0" 
                                           id="email" 
                                           name="email" 
                                           value="<%= formData.email || '' %>" 
                                           placeholder="tu@email.com" 
                                           required>
                                </div>
                                <div class="form-text">Debe ser el email con el que te registraste.</div>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="bi bi-send me-2"></i> Enviar enlace de recuperación
                                </button>
                            </div>

                            <div class="text-center">
                                <a href="/auth/login" class="text-decoration-none">
                                    <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
                                </a>
                            </div>
                        </form>

                        <hr class="my-4">

                        <div class="text-center text-muted small">
                            <p class="mb-0">
                                <i class="bi bi-shield-check me-1"></i> 
                                Tu seguridad es importante. El enlace expirará en 1 hora.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>