<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <a href="/" class="text-decoration-none">
                                <h1 class="h3 fw-bold text-success">PURO</h1>
                                <p class="text-muted small">Premium Natural Shots</p>
                            </a>
                            <h2 class="h4 fw-bold mt-3">Restablecer contraseña</h2>
                            <p class="text-muted">Crea una nueva contraseña para tu cuenta.</p>
                        </div>

                        <% if (errors && errors.length > 0) { %>
                            <div class="alert alert-danger border-0 bg-light-danger mb-4">
                                <ul class="mb-0 ps-3">
                                    <% errors.forEach(error => { %>
                                        <li><%= error.msg %></li>
                                    <% }); %>
                                </ul>
                            </div>
                        <% } %>

                        <form method="POST" action="/auth/reset-password">
                            <input type="hidden" name="token" value="<%= token %>">
                            
                            <div class="mb-4">
                                <label for="password" class="form-label fw-semibold">Nueva contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input type="password" 
                                           class="form-control border-start-0" 
                                           id="password" 
                                           name="password" 
                                           value="<%= formData.password || '' %>" 
                                           placeholder="Mínimo 6 caracteres" 
                                           required>
                                </div>
                                <div class="form-text">Debe contener mayúscula, minúscula y número.</div>
                            </div>

                            <div class="mb-4">
                                <label for="confirm_password" class="form-label fw-semibold">Confirmar contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-lock-fill text-muted"></i>
                                    </span>
                                    <input type="password" 
                                           class="form-control border-start-0" 
                                           id="confirm_password" 
                                           name="confirm_password" 
                                           value="<%= formData.confirm_password || '' %>" 
                                           placeholder="Repite la contraseña" 
                                           required>
                                </div>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="bi bi-check-circle me-2"></i> Restablecer contraseña
                                </button>
                            </div>

                            <div class="text-center">
                                <a href="/auth/login" class="text-decoration-none">
                                    <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
                                </a>
                            </div>
                        </form>

                        <hr class="my-4">

                        <div class="text-center text-muted small">
                            <p class="mb-0">
                                <i class="bi bi-info-circle me-1"></i> 
                                Asegúrate de que tu contraseña sea segura y no la compartas.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>